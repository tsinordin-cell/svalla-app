NEXT_PUBLIC_SUPABASE_URL=https://DITT_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din_anon_nyckel
SUPABASE_SERVICE_ROLE_KEY=sb_secret_din_nyckel
ANTHROPIC_API_KEY=sk-ant-din-nyckel-här

# Distribuerad rate limit (valfri — utan dessa används in-memory fallback,
# vilket inte fungerar cross-instance i Vercel/serverless).
# Skapa konto på upstash.com → ny Redis-databas → kopiera REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Push notifications (web-push)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@svalla.se

# Stripe (subscription)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTH=
STRIPE_PRICE_YEAR=

# Cron / admin endpoints
CRON_SECRET=
BACKFILL_SECRET=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
