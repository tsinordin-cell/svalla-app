{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/blogg/[slug]",
      "regex": "^/blogg/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blogg/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/platser/[id]",
      "regex": "^/platser/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/platser/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/rutter/[id]",
      "regex": "^/rutter/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/rutter/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/tur/[id]",
      "regex": "^/tur/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/tur/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/u/[username]",
      "regex": "^/u/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/u/(?<nxtPusername>[^/]+?)(?:/)?$"
    }
  ],
